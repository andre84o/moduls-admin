// Prisma schema — shared multi-tenant Supabase (PostgreSQL) database.
// One database holds MANY businesses. Every business-owned table has businessId.
// Connection: prisma.config.ts (CLI) and lib/prisma.ts (runtime driver adapter).
// Architecture rules: see CLAUDE.md (tenant isolation is mandatory).

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Core / platform models ───────────────────────────────────────────

/// A client company. The tenant root — everything hangs off this.
model Business {
  id        String         @id @default(cuid())
  name      String
  slug      String         @unique
  status    BusinessStatus @default(ACTIVE)
  logoUrl   String?
  website   String?
  phone     String?
  email     String?
  address   String?
  settings  Json?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  members      BusinessMember[]
  projects     Project[]
  properties   Property[]
  customers    Customer[]
  crmNotes     CrmNote[]
  services     Service[]
  bookings     Booking[]
  availability Availability[]
  blockedTimes BlockedTime[]
  media        Media[]
  auditLogs    AuditLog[]
  notifications Notification[]

  @@map("businesses")
}

/// A login user. Authentication is handled by Supabase Auth; we only mirror the
/// Supabase user id here. Passwords NEVER live in Prisma.
model User {
  id         String           @id @default(cuid())
  supabaseId String           @unique
  email      String           @unique
  username   String?
  firstName  String?
  lastName   String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  memberships BusinessMember[]
  crmNotes    CrmNote[]
  auditLogs   AuditLog[]

  @@map("users")
}

/// Connects a user to a business with a role. Access control lives here, never
/// as a single global role on User.
model BusinessMember {
  id         String     @id @default(cuid())
  businessId String
  userId     String
  role       MemberRole @default(STAFF)
  createdAt  DateTime   @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@index([userId])
  @@map("business_members")
}

/// A module/system enabled for a business (CRM, BOOKING, WEBSITE, ...).
model Project {
  id         String        @id @default(cuid())
  businessId String
  name       String
  type       ProjectType
  status     ProjectStatus @default(ACTIVE)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@map("projects")
}

/// Important admin actions, scoped per business.
model AuditLog {
  id         String   @id @default(cuid())
  businessId String
  userId     String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@map("audit_logs")
}

// ─── Bostäder (properties) + media ────────────────────────────────────

model Property {
  id          String         @id @default(cuid())
  businessId  String
  title       String
  slug        String?
  description String?
  location    String
  // Legacy generic price (kept for backward-compat with existing admin UI).
  // Booking math reads pricePerNight, never this. Remove in a later cleanup.
  price       Int?
  bedrooms    Int?
  status      PropertyStatus @default(PUBLISHED)

  // ── RENTAL booking settings ─────────────────────────────────────────
  // Money is stored in MINOR units (öre/cents) for Stripe-safe integer math.
  pricePerNight           Int?
  cleaningFee             Int?     @default(0)
  currency                String   @default("sek")
  minNights               Int      @default(1)
  maxGuests               Int?
  maxAdults               Int?
  maxChildren             Int?
  maxInfants              Int?
  maxPets                 Int?     @default(0)
  petsAllowed             Boolean  @default(false)
  bufferDaysAfterCheckout Int      @default(0)
  cancellationDeadlineDays Int?

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  bookings     Booking[]
  media        Media[]
  blockedTimes BlockedTime[]

  // Public route key (app/p/[slug]). Nullable slugs stay allowed — Postgres
  // treats NULLs as distinct, so many properties may have no slug yet.
  @@unique([businessId, slug])
  @@index([businessId])
  @@map("properties")
}

/// Central media library. One shared store for every business-owned image and
/// document. Files live in Supabase Storage under businesses/{businessId}/...
/// and can be attached to ANY entity via the generic (ownerType, ownerId) pair
/// — or to a Property directly via the typed propertyId relation. Images are
/// compressed on upload (see lib/storage.ts); width/height/size describe the
/// stored file.
model Media {
  id         String          @id @default(cuid())
  businessId String
  propertyId String?
  // Generic attach target so any feature can link media without a schema change.
  // ownerType is validated against a server-side whitelist and ownerId is always
  // verified to belong to businessId before create/list (see lib/media.ts).
  ownerType  String?
  ownerId    String?
  kind       MediaKind       @default(IMAGE)
  // PUBLIC files live in the public bucket and store a permanent `url`.
  // PRIVATE files (all documents + customer files) live in the private bucket;
  // `url` is null and a short-lived signed URL is generated on read. Visibility
  // is decided server-side, never trusted from the client.
  visibility MediaVisibility @default(PRIVATE)
  folder     String          @default("general")
  name       String?
  url        String?
  path       String
  type       String
  size       Int?
  width      Int?
  height     Int?
  alt        String?
  createdAt  DateTime        @default(now())

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([businessId, ownerType, ownerId])
  @@index([businessId, kind])
  @@map("media")
}

// ─── CRM ──────────────────────────────────────────────────────────────

model Customer {
  id         String        @id @default(cuid())
  businessId String
  number     Int?
  name       String
  firstName  String?
  lastName   String?
  email      String?
  phone      String?
  mobile     String?
  address    String?
  postalCode String?
  country    String?
  gender     String?
  note       String?       @db.Text
  stage      CustomerStage @default(LEAD)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  notes    CrmNote[]
  bookings Booking[]

  @@unique([businessId, number])
  @@index([businessId])
  @@map("customers")
}

model CrmNote {
  id         String   @id @default(cuid())
  businessId String
  customerId String
  userId     String?
  body       String
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([customerId])
  @@map("crm_notes")
}

// ─── Booking + calendar ───────────────────────────────────────────────

model Service {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  durationMin Int      @default(60)
  price       Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([businessId])
  @@map("services")
}

model Booking {
  id         String        @id @default(cuid())
  businessId String
  propertyId String?
  serviceId  String?
  customerId String?
  guestName  String
  guestEmail String?
  startAt    DateTime
  endAt      DateTime
  status     BookingStatus @default(PENDING)
  notes      String?

  // ── Guest breakdown ─────────────────────────────────────────────────
  adults   Int @default(1)
  children Int @default(0)
  infants  Int @default(0)
  pets     Int @default(0)

  // ── Price snapshot (minor units) taken server-side at booking time ──
  nights                Int?
  pricePerNightSnapshot Int?
  cleaningFeeSnapshot   Int?    @default(0)
  totalAmount           Int?
  currency              String  @default("sek")

  // ── Payment (Stripe) — booking is only CONFIRMED via verified webhook ─
  stripeSessionId       String? @unique
  stripePaymentIntentId String?
  paid                  Boolean @default(false)
  // While PAYMENT_PENDING the dates are held; expired holds are released.
  holdExpiresAt         DateTime?

  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  service  Service?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([businessId, startAt])
  @@index([businessId, propertyId, startAt])
  @@map("bookings")
}

/// Recurring weekly working hours for the calendar. weekday: 0=Sun..6=Sat.
model Availability {
  id          String   @id @default(cuid())
  businessId  String
  weekday     Int
  startMinute Int
  endMinute   Int

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@map("availability")
}

/// One-off blocked range (holiday, maintenance) — removes slots from calendar.
/// propertyId scopes the block to one property; null = business-wide block.
model BlockedTime {
  id         String   @id @default(cuid())
  businessId String
  propertyId String?
  startAt    DateTime
  endAt      DateTime
  reason     String?

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, propertyId])
  @@map("blocked_times")
}

// ─── Mail notifications log ───────────────────────────────────────────

/// Record of every email we attempted to send (to customer or admin).
model Notification {
  id         String             @id @default(cuid())
  businessId String
  channel    String             @default("email")
  recipient  String
  audience   NotificationAudience
  subject    String
  status     NotificationStatus @default(SENT)
  error      String?
  createdAt  DateTime           @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@map("notifications")
}

// ─── Enums ────────────────────────────────────────────────────────────

enum BusinessStatus {
  ACTIVE
  SUSPENDED
}

enum MemberRole {
  SUPER_ADMIN
  OWNER
  ADMIN
  STAFF
}

enum ProjectType {
  CRM
  BOOKING
  WEBSITE
  RENTAL
  ECOMMERCE
  CUSTOM
}

enum ProjectStatus {
  ACTIVE
  DISABLED
}

enum PropertyStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MediaKind {
  IMAGE
  DOCUMENT
}

enum MediaVisibility {
  PUBLIC
  PRIVATE
}

enum CustomerStage {
  LEAD
  CONTACTED
  CUSTOMER
}

enum BookingStatus {
  PENDING
  PAYMENT_PENDING
  CONFIRMED
  DECLINED
  CANCELLED
  EXPIRED
  REFUNDED
}

enum NotificationAudience {
  CUSTOMER
  ADMIN
}

enum NotificationStatus {
  SENT
  FAILED
  SKIPPED
}
