# Copy to .env and fill in the values. NEVER commit real secrets.

# ─── Supabase / Postgres (Prisma) ─────────────────────────────────────
# Supabase: Project → Connect → ORMs (Prisma).
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ─── Supabase Auth + Storage (browser-safe public values) ─────────────
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[ANON-KEY]"

# Server-only service role key — NEVER expose to the browser.
# Used for trusted storage operations (image upload/delete).
SUPABASE_SERVICE_ROLE_KEY="[SERVICE-ROLE-KEY]"
# Two storage buckets (create both in Supabase Storage):
#   PUBLIC  — website images/logos (permanent URLs)
#   PRIVATE — documents + customer files (short-lived signed URLs)
SUPABASE_PUBLIC_BUCKET="media-public"
SUPABASE_PRIVATE_BUCKET="media-private"

# ─── Email notifications (Resend) ─────────────────────────────────────
# https://resend.com → API Keys. Leave unset to skip sending (logged only).
RESEND_API_KEY=""
EMAIL_FROM="Demo Estates <onboarding@resend.dev>"
# Fallback admin recipient if a business has no email set.
ADMIN_EMAIL="admin@demo.local"
